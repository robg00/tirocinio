{
  "title": "Stream Analytics - Tirocinio",
  "uid": "stream_analytics",
  "version": 2,
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Vendite per fascia di prezzo",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cnt"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "displayName",
                "value": "Vendite"
              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT value_band, SUM(total_amount) AS revenue, COUNT(*) AS cnt FROM fact_sales GROUP BY value_band ORDER BY revenue DESC",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Vendite nel tempo",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', event_timestamp::timestamp) AS \"time\", SUM(total_amount) AS revenue FROM fact_sales GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Anomalie per tipo",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "displayLabels": [
          "percent",
          "name"
        ],
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT anomaly_type, COUNT(*) AS cnt FROM anomaly_alerts GROUP BY anomaly_type ORDER BY cnt DESC",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Anomalie nel tempo",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', detected_at) AS \"time\", COUNT(*) AS anomalies FROM anomaly_alerts GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Ultima finestra aggregazione",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT sale_count, total_revenue, avg_order_value, window_end FROM agg_sales_windowed ORDER BY window_end DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Vendite per ora",
      "type": "barchart",
      "gridPos": {
        "x": 4,
        "y": 16,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "revenue"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT sale_hour, COUNT(*) AS cnt, SUM(total_amount) AS revenue FROM fact_sales GROUP BY sale_hour ORDER BY sale_hour",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top 10 prodotti per quantit\u00e0",
      "type": "barchart",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT product_id, SUM(quantity) AS qty FROM fact_sales GROUP BY product_id ORDER BY qty DESC LIMIT 10",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Ultime anomalie",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 18,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PCC52D03280B7034C"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        }
      },
      "options": {
        "sortBy": [
          {
            "displayName": "detected_at",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT sale_id, anomaly_type, anomaly_code, detected_at FROM anomaly_alerts ORDER BY detected_at DESC LIMIT 20",
          "refId": "A"
        }
      ]
    }
  ]
}